{
  "entities": {
    "WaitlistEntry": {
      "title": "WaitlistEntry",
      "description": "A user who has signed up for the waitlist.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the user joined the waitlist."
        }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "waitlist/{entryId}": {
      "schema": "WaitlistEntry",
      "description": "Collection of waitlist signups."
    }
  }
}
